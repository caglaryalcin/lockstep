{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Personal Security Checklist",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "title": { "type": "string" },
      "slug": { "type": "string" },
      "description": { "type": "string" },
      "intro": { "type": "string" },
      "icon": { "type": "string" },
      "color": { "type": "string" },
      "checklist": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "point": { "type": "string" },
            "priority": {
              "type": "string",
              "enum": [
                "Basic",
                "Essential",
                "Recommended",
                "Optional",
                "Advanced",
                "basic",
                "essential",
                "recommended",
                "optional",
                "advanced"
              ]
            },
            "details": { "type": "string" }
          },
          "required": ["point", "priority", "details"]
        }
      }
    },
    "required": ["title", "slug", "description", "intro", "icon", "color", "checklist"],
    "additionalProperties": false
  }
}
